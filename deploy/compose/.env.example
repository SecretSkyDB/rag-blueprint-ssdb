# Copy to `.env` and fill in. Read by all the docker-compose-*.yaml files.

# ----- NVIDIA -------------------------------------------------------
# Get from https://build.nvidia.com (sign-in -> "Get API Key").
# Used by ingestor-server, rag-server, and ssdb-sql-rag for embedding
# + LLM calls against NVIDIA-hosted NIMs (or against the build.nvidia.com
# hosted models if no self-hosted NIM URL is set).
NVIDIA_API_KEY=

# ----- SSDB share-holders -------------------------------------------
# Postgres password shared by ssdb-share-1/2/3. Each shareholder is an
# independent Postgres instance; this password protects connection,
# not data (data is secret-shared at the SQL layer above).
SSDB_SHARE_PWD=please-change-me

# ----- Optional pinning ---------------------------------------------
# Override these to pin a specific upstream RAG Blueprint release or
# SSDB release. Defaults track the most recently verified pair.
RAG_VERSION=2.5.0
SSDB_VERSION=0.1.0

# ----- Optional model overrides -------------------------------------
# Defaults match NVIDIA RAG Blueprint v2.5.0 / change-model.html.
# Self-hosted overrides go in the *_SERVERURL vars (point at NIMs).
APP_LLM_MODELNAME=nvidia/llama-3.3-nemotron-super-49b-v1.5
APP_LLM_SERVERURL=
APP_EMBEDDINGS_MODELNAME=nvidia/nv-embedqa-e5-v5
APP_EMBEDDINGS_SERVERURL=
APP_EMBEDDINGS_DIMENSIONS=1024
APP_RANKING_MODELNAME=nvidia/llama-3.2-nv-rerankqa-1b-v2
APP_RANKING_SERVERURL=

# ----- Collection ---------------------------------------------------
APP_COLLECTION_NAME=nv_rag_documents
